# Copy this file to .env and fill in your key. Any OpenAI-compatible endpoint works.

# Your API key (OpenRouter, OpenAI, xAI, ...)
LLM_API_KEY=

# OpenAI-compatible base URL. Defaults to OpenRouter if unset.
LLM_BASE_URL=https://openrouter.ai/api/v1

# Model id at that endpoint. Defaults to a cheap, capable model if unset.
LLM_MODEL=openai/gpt-4o-mini

# Optional. Set this to generate REAL images via Replicate (Google Nano Banana 2).
# Leave it empty and the generateImage tool falls back to a deterministic stub,
# so the demo still runs offline and for free.
REPLICATE_API_TOKEN=
